generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────── Identity & privacy

enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  // GDPR: soft delete first, hard purge by scheduled job after grace period.
  deletedAt    DateTime?
  // Moderation: suspension blocks login without triggering erasure.
  suspendedAt     DateTime?
  suspendedReason String?
  // Email verification: sign-in is blocked until verified. Existing accounts
  // are backfilled as verified at migration time.
  emailVerifiedAt      DateTime?
  verifyTokenHash      String?   @unique
  verifyTokenExpiresAt DateTime?
  // Self-service email change (see AccountSettingsForm.tsx / api/account/email):
  // the new address isn't applied to `email` until its confirmation link is
  // clicked, so a mistyped address can never lock the owner out of sign-in.
  pendingEmail                String?
  pendingEmailTokenHash        String?   @unique
  pendingEmailTokenExpiresAt   DateTime?
  // Forgot-password flow (see lib/verification.ts): a short-lived, single-use
  // token mailed on request. Kept separate from verifyTokenHash since this one
  // grants immediate account access and expires much sooner (1h vs 24h).
  resetPasswordTokenHash       String?   @unique
  resetPasswordTokenExpiresAt  DateTime?

  candidate     CandidateProfile?
  company       Company?          @relation("CompanyOwner")
  consents      ConsentRecord[]
  dataRequests  DataRequest[]
  messages      Message[]
  reports       Report[]          @relation("Reporter")
  blogPosts     BlogPost[]        @relation("EditorialAuthor")
  auditEntries  AdminAuditLog[]   @relation("AuditAdmin")
  notifications Notification[]
}

enum NotificationType {
  APPLICATION_STATUS
  NEW_MESSAGE
  SAVED_SEARCH_MATCH
}

// In-app notifications shown via the header bell and /dashboard/notifications.
// Always written alongside (not instead of) the equivalent email — see
// src/lib/notify.ts, the single call site that creates these.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// Immutable audit trail of consent — never update rows, only append.
model ConsentRecord {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ConsentType
  granted   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([userId, type, createdAt])
}

enum ConsentType {
  TERMS
  PRIVACY_POLICY
  MARKETING_EMAIL
  PROFILE_VISIBILITY // explicit consent that verified employers may view profile
  COOKIES_ANALYTICS
}

// GDPR Art. 15 (access/export) and Art. 17 (erasure) request tracking.
model DataRequest {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        DataRequestType
  status      DataRequestStatus @default(PENDING)
  requestedAt DateTime          @default(now())
  completedAt DateTime?
  notes       String?
}

enum DataRequestType {
  EXPORT
  DELETE
}

enum DataRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

// ─────────────────────────────────────────────── Candidates

enum ProfileVisibility {
  PRIVATE // visible to nobody except the candidate + companies they applied to
  PUBLIC  // visible ONLY to authenticated, admin-verified employers (server-enforced)
}

enum FifoPreference {
  FIFO
  DIDO
  RESIDENTIAL
  FLEXIBLE
}

enum SiteExperience {
  OPEN_PIT
  UNDERGROUND
  PROCESSING_PLANT
  EXPLORATION
  PORT_RAIL
  SMELTER_REFINERY
  WORKSHOP_MAINTENANCE
  CORPORATE_OFFICE
}

enum Commodity {
  GOLD
  IRON_ORE
  COAL
  COPPER
  LITHIUM
  NICKEL
  BAUXITE_ALUMINA
  URANIUM
  MINERAL_SANDS
  RARE_EARTHS
  ZINC_LEAD
  OIL_GAS
  OTHER
}

model CandidateProfile {
  id                String            @id @default(cuid())
  userId            String            @unique
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName         String
  lastName          String
  headline          String?
  summary           String?
  phone             String?
  countryCode       String? // ISO 3166-1 alpha-2
  region            String?
  city              String?
  visibility        ProfileVisibility @default(PRIVATE)
  photoKey          String? // S3 object keys, never public URLs
  resumeKey         String?
  resumeName        String? // original filename, for display only
  coverLetterKey    String?
  coverLetterName   String? // original filename, for display only
  yearsExperience   Int?
  fifoPreference    FifoPreference?
  willingToRelocate Boolean           @default(false)
  availableFrom     DateTime?
  siteExperience    SiteExperience[]
  commodities       Commodity[]
  // Self-declared right-to-work countries (ISO 3166-1 alpha-2 codes), picked
  // from the fixed list in src/lib/countries.ts so entries stay uniform.
  // Not verified by the platform — see ProfileForm.tsx for the disclaimer
  // shown to candidates, and CandidateSearch.tsx for how it's surfaced to
  // employers as a signal only, pointing at Certifications & Tickets for proof.
  rightToWorkCountries String[]       @default([])
  updatedAt         DateTime          @updatedAt

  certifications    Certification[]
  employmentHistory EmploymentHistory[]
  applications      Application[]
  bookmarks         JobBookmark[]
  followedCompanies CompanyFollow[]
  bookmarkedBy      CandidateBookmark[]
  threads           MessageThread[]
  promotions        PromotionListing[]
  companyReviews    CompanyReview[]
  savedSearches     SavedSearch[]

  @@index([visibility])
  @@index([countryCode, region])
}

// Job alerts: a candidate's saved filter combination, checked by the daily
// cron (sendSavedSearchAlerts in src/lib/cron.ts) for jobs published since
// lastNotifiedAt. All criteria are optional/ANDed — a blank field means "any".
enum AlertFrequency {
  DAILY
  WEEKLY
}

model SavedSearch {
  id             String           @id @default(cuid())
  candidateId    String
  candidate      CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  label          String? // candidate-facing name, e.g. "Gold FIFO WA"
  commodity      Commodity?
  siteType       SiteExperience?
  countryCode    String?
  fifoOnly       Boolean          @default(false)
  minSalary      Int?
  frequency      AlertFrequency   @default(DAILY)
  createdAt      DateTime         @default(now())
  lastNotifiedAt DateTime? // jobs published after this are "new" for the next alert

  @@index([candidateId])
}

// Tickets & certs: "HR licence", "Working at Heights", "First Aid", site inductions...
model Certification {
  id          String           @id @default(cuid())
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name        String
  issuer      String?
  referenceNo String?
  expiresAt   DateTime?
  documentKey String? // optional scan upload
  // Set server-side only, never accepted from the candidate directly.
  // Attaching a new/changed document moves this to PENDING; an admin then
  // approves or rejects it, same flow as company KYB.
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime?
  verificationNotes  String? // admin notes, e.g. reason for rejection

  @@index([verificationStatus])
}

// Structured, per-role work history — separate from the coarse
// siteExperience/commodities tags on CandidateProfile. Optional proof
// upload (payslip, reference letter) can be verified by an admin, same
// UNVERIFIED → PENDING → VERIFIED/REJECTED flow as Certification and KYB.
model EmploymentHistory {
  id          String           @id @default(cuid())
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  companyName String
  title       String
  siteType    SiteExperience?
  commodity   Commodity?
  startDate   DateTime
  endDate     DateTime? // null = current role
  documentKey String?
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime?
  verificationNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([candidateId])
  @@index([verificationStatus])
}

// ─────────────────────────────────────────────── Employers & companies

enum VerificationStatus {
  UNVERIFIED
  PENDING // KYB docs submitted, awaiting admin review
  VERIFIED
  REJECTED
}

model Company {
  id                 String             @id @default(cuid())
  ownerId            String             @unique
  owner              User               @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name               String
  slug               String             @unique
  website            String?
  description        String?
  logoKey            String?
  galleryKeys        String[]           @default([]) // employer branding photos, shown on the company page
  videoUrl           String? // YouTube/Vimeo link, embedded on the company page
  countryCode        String?
  size               String?
  verificationStatus VerificationStatus @default(UNVERIFIED)
  kybDocumentKey     String? // business registration doc for admin review
  kybNotes           String?
  createdAt          DateTime           @default(now())

  jobs           Job[]
  subscription   Subscription?
  blogPosts      BlogPost[]
  followers      CompanyFollow[]
  bookmarks      CandidateBookmark[]
  threads        MessageThread[]
  overages       OveragePurchase[]
  reviews        CompanyReview[]
  jobFeeds       JobFeed[]

  @@index([verificationStatus])
}

// ─────────────────────────────────────────────── RSS / XML job feeds

enum JobFeedStatus {
  ACTIVE
  PAUSED
  ERROR
}

model JobFeed {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  url           String
  label         String? // e.g. "BHP Careers — Australia"
  status        JobFeedStatus @default(ACTIVE)
  lastFetchedAt DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  lastSummary   Json? // { fetched, created, updated, drafted, skippedDuplicates, expired }
  createdAt     DateTime      @default(now())

  @@index([status])
}

// ─────────────────────────────────────────────── Jobs

enum JobStatus {
  DRAFT
  PENDING_REVIEW // awaiting admin approval (new/untrusted companies or spam-flagged)
  PUBLISHED
  EXPIRED
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  CASUAL
  APPRENTICESHIP
}

enum SalaryPeriod {
  HOUR
  DAY
  YEAR
}

enum JobSource {
  MANUAL
  CSV
  RSS // Phase 2
}

model Job {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title          String
  slug           String         @unique
  description    String
  roleCategory   String? // e.g. "Drill & Blast", "Fixed Plant Maintenance", "Geology"
  commodity      Commodity?
  employmentType EmploymentType @default(FULL_TIME)
  siteType       SiteExperience?
  fifo           Boolean        @default(false)
  rosterPattern  String? // e.g. "2/1", "8/6", "5/2"
  countryCode    String // ISO 3166-1 alpha-2 — global from day one
  region         String?
  city           String?
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String? // ISO 4217: AUD, USD, CAD, ZAR, CLP...
  salaryPeriod   SalaryPeriod?
  applyUrl       String? // external ATS link (used by CSV/RSS imports)
  status         JobStatus      @default(DRAFT)
  source         JobSource      @default(MANUAL)
  externalRef    String? // dedupe key for CSV/RSS re-imports
  reviewNotes    String? // admin rejection reason, surfaced to the employer
  moderationFlags String[] @default([]) // spam-heuristic flags set at submission
  isPriority     Boolean        @default(false) // Gold tier placement
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())

  applications Application[]
  bookmarks    JobBookmark[]

  @@unique([companyId, externalRef])
  @@index([status, publishedAt])
  @@index([countryCode, region])
  @@index([commodity])
}

enum ApplicationStatus {
  SUBMITTED
  VIEWED
  SHORTLISTED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   CandidateProfile  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status      ApplicationStatus @default(SUBMITTED)
  coverNote   String? // candidate's own note, set at application time
  notes       String? // employer's private hiring notes — never shown to the candidate
  resumeKey       String? // snapshot at time of application — either the
  // candidate's profile default, or a one-off resume uploaded just for this
  // job (see /api/applications). Either way, this is exactly what the
  // employer sees, and never changes the candidate's profile default.
  resumeName      String? // original filename, for display only
  coverLetterKey  String? // same snapshot pattern as resumeKey, optional
  coverLetterName String? // original filename, for display only
  // Set once, the first time status moves to INTERVIEW or OFFER — kept even
  // if later rejected, so review eligibility reflects "ever reached
  // interview stage" rather than the current (possibly overwritten) status.
  interviewedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, candidateId])
  @@index([candidateId, createdAt])
}

model JobBookmark {
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@id([candidateId, jobId])
}

model CompanyFollow {
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@id([candidateId, companyId])
}

model CandidateBookmark {
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@id([companyId, candidateId])
}

// ─────────────────────────────────────────────── Billing

enum PlanTier {
  BRONZE // $299/mo — 25 ads
  SILVER // $599/mo — 50 ads
  GOLD   // $999/mo — 100 ads + resume database search + priority placement
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model Subscription {
  id                   String             @id @default(cuid())
  companyId            String             @unique
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tier                 PlanTier
  status               SubscriptionStatus @default(INCOMPLETE)
  stripeCustomerId     String             @unique
  stripeSubscriptionId String             @unique
  currentPeriodEnd     DateTime?
  jobsUsedThisPeriod   Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model OveragePurchase {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stripeSessionId String   @unique
  amountCents     Int
  currency        String   @default("usd")
  consumed        Boolean  @default(false) // one purchase = one extra job slot
  refundedAt      DateTime? // set when an admin refunds this purchase
  createdAt       DateTime @default(now())
}

// Phase 2: candidate "Promote Me" listings. Modeled now so migrations stay clean.
enum PromotionTier {
  DAYS_30 // $29
  DAYS_90 // $79
}

model PromotionListing {
  id              String           @id @default(cuid())
  candidateId     String
  candidate       CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  tier            PromotionTier
  headline        String
  pitch           String
  stripeSessionId String?          @unique
  paidAt          DateTime?
  expiresAt       DateTime?
  createdAt       DateTime         @default(now())

  @@index([expiresAt])
}

// ─────────────────────────────────────────────── Messaging

model MessageThread {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  messages Message[]

  @@unique([companyId, candidateId])
}

model Message {
  id           String        @id @default(cuid())
  threadId     String
  thread       MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUserId String
  sender       User          @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  body         String
  readAt       DateTime?
  createdAt    DateTime      @default(now())

  @@index([threadId, createdAt])
  @@index([senderUserId, createdAt]) // powers rate limiting
}

// ─────────────────────────────────────────────── Content & moderation

enum BlogPostType {
  COMPANY
  EDITORIAL
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  HIDDEN // moderated off
}

model BlogPost {
  id          String         @id @default(cuid())
  type        BlogPostType
  companyId   String?
  company     Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?          @relation("EditorialAuthor", fields: [authorId], references: [id])
  title       String
  slug        String         @unique
  excerpt     String?
  body        String
  coverKey    String?
  coverAlt    String?
  status      BlogPostStatus @default(DRAFT)
  curatedRank Int? // admin-set homepage ordering; null = not featured
  publishedAt DateTime?
  createdAt   DateTime       @default(now())

  images BlogPostImage[]

  @@index([status, publishedAt])
  @@index([curatedRank])
}

// Gallery images for company posts (site/facility showcases). Alt text is
// mandatory for accessibility and SEO.
model BlogPostImage {
  id      String   @id @default(cuid())
  postId  String
  post    BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  key     String
  altText String
  order   Int      @default(0)

  @@index([postId, order])
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  reporter   User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType String // "JOB" | "MESSAGE" | "BLOG_POST" | "PROFILE" | "COMPANY"
  targetId   String
  reason     String
  status     ReportStatus @default(OPEN)
  resolutionNote String?
  resolvedAt     DateTime?
  createdAt  DateTime     @default(now())
}

// ─────────────────────────────────────────────── Admin audit trail

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation("AuditAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  action     String // e.g. "JOB_APPROVE", "USER_SUSPEND", "REFUND_ISSUE"
  targetType String // "JOB" | "USER" | "COMPANY" | "REPORT" | "BLOG_POST" | "PAYMENT" | "CERTIFICATION" | "EMPLOYMENT_HISTORY"
  targetId   String
  notes      String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetId])
}

// ─────────────────────────────────────────────── Ops: analytics, email, cron

// One row per UTC day, populated by the daily cron (and backfilled on demand).
model DailyStat {
  id                  String   @id @default(cuid())
  date                DateTime @unique
  candidateSignups    Int      @default(0)
  employerSignups     Int      @default(0)
  jobsPosted          Int      @default(0)
  applications        Int      @default(0)
  activeSubs          Int      @default(0)
  mrrCents            Int      @default(0)
  mrrCentsBronze      Int      @default(0)
  mrrCentsSilver      Int      @default(0)
  mrrCentsGold        Int      @default(0)
  churnedSubs         Int      @default(0)
  overageRevenueCents Int      @default(0)
}

model EmailLog {
  id          String   @id @default(cuid())
  to          String
  subject     String
  template    String // "KYB_DECISION" | "JOB_REJECTED" | "USER_SUSPENDED" | "BROADCAST" | ...
  body        String
  status      String // "SENT" | "FAILED"
  error       String?
  broadcastId String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([to])
}

model Broadcast {
  id          String   @id @default(cuid())
  subject     String
  body        String
  segment     String // human-readable audience description
  recipients  Int      @default(0)
  sent        Int      @default(0)
  failed      Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
}

model CronRun {
  id         String    @id @default(cuid())
  job        String // "expire-jobs" | "purge-deleted" | "daily-rollup"
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  ok         Boolean?
  detail     String?

  @@index([job, startedAt])
}

// ─────────────────────────────────────────────── Employer reviews

enum ReviewStatus {
  PUBLISHED
  HIDDEN // moderated off via the report pipeline
}

// One review per candidate per company; only candidates who applied may review.
model CompanyReview {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  rating      Int // 1–5, validated at the API layer
  title       String?
  body        String
  status      ReviewStatus     @default(PUBLISHED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([companyId, candidateId])
  @@index([companyId, status])
}
