# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fifodido"

# --- Auth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_BRONZE="price_..."   # $299/mo, 25 ads
STRIPE_PRICE_SILVER="price_..."   # $599/mo, 50 ads
STRIPE_PRICE_GOLD="price_..."     # $999/mo, 100 ads + resume search
STRIPE_PRICE_OVERAGE="price_..."  # one-time pay-per-post beyond quota ($149-249)
STRIPE_PRICE_PROMOTE_30="price_..." # Phase 2: Promote Me $29/30d
STRIPE_PRICE_PROMOTE_90="price_..." # Phase 2: Promote Me $79/90d

# --- S3-compatible storage (AWS S3, Cloudflare R2, MinIO, Wasabi...) ---
S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="fifodido"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Email (Resend — https://resend.com; leave empty to log-only in dev) ---
RESEND_API_KEY=""
EMAIL_FROM="FiFoDiDo <notifications@yourdomain.com>"

# --- Cron protection (Vercel Cron sends this automatically when set) ---
CRON_SECRET=""

# --- Cloudflare Turnstile (bot protection on /register) ---
# Create a Turnstile widget at https://dash.cloudflare.com/?to=/:account/turnstile
# Widget mode: "Managed" is a good default (usually invisible, occasional challenge).
# Until both keys below are set, registration works as before with no bot check.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
